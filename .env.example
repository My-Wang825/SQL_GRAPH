# 复制为 .env 或直接在系统环境变量中设置（勿将含真实密钥的 .env 提交到 Git）
OPENAI_BASE_URL=https://api.example.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=your-model-name

# 治理平台数据库（SQL 来源）
DB_HOST=200.120.5.214
DB_PORT=3306
DB_USER=datablau
# 密码若含 #、空格等，必须用双引号或单引号括起来，否则 # 会被当成注释截断
# 示例: DB_PASSWORD="myp@ss#123"
DB_PASSWORD=your-db-password
DB_NAME=datablau_ddd

# 治理库失败时是否用仓库 data/<板块>/ 本地 SQL 构图（默认不配=否，生产请仅用库 content）
# GRAPH_LOCAL_SQL_FALLBACK=1

# 指标平台 queryAll 血缘（可选；不配则 /api/metrics/lineage/summary 不可用）
METRICS_LINEAGE_QUERY_ALL_URL=
METRICS_TENANT_ID=
METRICS_AUTH_TYPE=UID
METRICS_AUTH_VALUE=
METRICS_HTTP_TIMEOUT_SEC=120
# 物化表识别：PHYSICAL_TABLE 的 vertexId 包含以下任一子串（逗号分隔）
METRICS_MATERIALIZED_HINTS=aloudatacan

# 电解铝 PRD_AL：与治理表对齐后并入 PHYSICAL_TABLE→DATASET（默认路径可改）
METRICS_GOVERNANCE_MERGE_JSON=exports/metrics_lineage_test/lineage_for_governance_merge.json